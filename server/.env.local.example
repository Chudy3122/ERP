# Local development overrides — copy to ".env.local" (gitignored) for localhost.
#
# Point localhost at a SEPARATE Neon branch so local testing never touches the
# production data. How to set up:
#   1. Neon console → your project → Branches → "New branch" (e.g. name it "dev").
#   2. Open the new branch → Connection string → copy the full "postgresql://..." URL.
#   3. Paste it below as DATABASE_URL and save this file as ".env.local".
#   4. Start the server locally — migrations run automatically on the dev branch.
#
# .env.local is loaded BEFORE .env and takes precedence, so production .env stays
# untouched. On Render there is no .env.local, so the platform env vars are used.

DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-dev.eu-central-1.aws.neon.tech/dbname?sslmode=require

# --- Outgoing e-mail (SMTP) — optional. Point at any existing mailbox.
# If unset, the app simply skips sending e-mails (bell notifications still work).
# Set the same vars on Render for production. For Gmail use an App Password.
# LH mail: host smtp.lh.pl, port 465, SSL. Username = full e-mail address.
SMTP_HOST=smtp.lh.pl
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=webmaster@itcomplete.pl
SMTP_PASS=your-mailbox-password
SMTP_FROM=ERP ITComplete <webmaster@itcomplete.pl>
